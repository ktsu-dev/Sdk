<Project Sdk="Microsoft.NET.Sdk">
  <!-- This is the test project (name == {SolutionName}.Test). Test projects are exempt from
       the analyzer/polyfill requirements; they bring their own test stack. -->
  <Sdk Name="ktsu.Sdk" />
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <TargetFrameworks></TargetFrameworks>
    <!-- Set explicitly: the SDK's name-based test detection is currently overridden by a
         later unconditional default, and that default also wins over the value
         Microsoft.NET.Test.Sdk sets, so the project would otherwise be treated as non-test. -->
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="MSTest.TestAdapter" />
    <PackageReference Include="MSTest.TestFramework" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Calculator\Calculator.csproj" />
  </ItemGroup>
</Project>
