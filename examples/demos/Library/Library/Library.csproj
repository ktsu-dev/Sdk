<Project Sdk="Microsoft.NET.Sdk">
  <!-- Core ktsu.Sdk: a multi-purpose library. Pinned to net10.0 here to keep the
       smoke test fast; the SDK multi-targets by default. -->
  <Sdk Name="ktsu.Sdk" />
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <TargetFrameworks></TargetFrameworks>
  </PropertyGroup>
  <ItemGroup>
    <!-- Standard packages required by KTSU0001 for non-test projects. -->
    <PackageReference Include="Polyfill" PrivateAssets="all" />
  </ItemGroup>
</Project>
