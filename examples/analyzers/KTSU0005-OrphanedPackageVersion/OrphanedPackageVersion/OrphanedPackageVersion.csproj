<Project Sdk="Microsoft.NET.Sdk">
  <!-- KTSU0005: Directory.Packages.props declares a PackageVersion (Newtonsoft.Json)
       that nothing references. The standard packages ARE referenced, so they are not
       orphans and KTSU0001 is satisfied. -->
  <Sdk Name="ktsu.Sdk" />
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <TargetFrameworks></TargetFrameworks>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Polyfill" PrivateAssets="all" />
  </ItemGroup>
</Project>
